meta {
  name: Manual GPX Upload
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/manage/races/gpx
  body: json
  auth: none
}

headers {
  x-admin-key: {{adminKey}}
}

body:json {
  {
    "url": "https://www.sormlandultra.se/banan/",
    "name": "Sörmland Ultra Marathon",
    "gpxFiles": [
      {
        "content": "base64 < ~/Downloads/Sörmland_Ultra_Marathon_50k.gpx| pbcopy",
        "name": "Sörmland Ultra Marathon",
        "distance": "50 km"
      }
    ]
  }
}
